class TestSensorNominal:
    """Normal operation — sensor produces noisy readings."""

    def test_reading_close_to_true_value(self):
        """Mean of many readings should be within 0.3°C of true value."""
        cfg    = SensorConfig(noise_std=0.5, dropout_prob=0.0, seed=1)
        sensor = Sensor(cfg)
        readings = [sensor.read(21.0) for _ in range(500)]
        assert abs(float(np.mean(readings)) - 21.0) < 0.3

    def test_noise_std_matches_config(self):
        """Empirical std of readings should be within 30% of noise_std."""
        cfg    = SensorConfig(noise_std=1.0, dropout_prob=0.0, seed=2)
        sensor = Sensor(cfg)
        readings = [sensor.read(20.0) for _ in range(1000)]
        assert 0.7 < float(np.std(readings)) < 1.3

    def test_bias_shifts_mean(self):
        """Mean reading should equal true_temp + bias."""
        cfg    = SensorConfig(noise_std=0.01, dropout_prob=0.0, bias=2.0, seed=3)
        sensor = Sensor(cfg)
        readings = [sensor.read(20.0) for _ in range(300)]
        assert abs(float(np.mean(readings)) - 22.0) < 0.1

    def test_stream_returns_correct_length(self):
        """stream() should return same number of values as input."""
        cfg    = SensorConfig(dropout_prob=0.0, seed=4)
        sensor = Sensor(cfg)
        result = sensor.stream([20.0, 21.0, 22.0, 23.0, 24.0])
        assert len(result) == 5

    def test_dropout_rate_approximately_correct(self):
        """Empirical dropout rate should be within 5pp of configured rate."""
        cfg    = SensorConfig(noise_std=0.1, dropout_prob=0.2, seed=5)
        sensor = Sensor(cfg)
        readings   = [sensor.read(20.0) for _ in range(2000)]
        n_dropped  = sum(1 for r in readings if r is None)
        empirical  = n_dropped / 2000
        assert abs(empirical - 0.2) < 0.05


class TestSensorEdgeCases:
    """Boundary conditions."""

    def test_zero_dropout_never_drops(self):
        """With dropout_prob=0, every reading should be non-None."""
        cfg    = SensorConfig(dropout_prob=0.0, seed=10)
        sensor = Sensor(cfg)
        for _ in range(100):
            assert sensor.read(21.0) is not None

    def test_full_dropout_always_none(self):
        """With dropout_prob=1.0, every reading should be None."""
        cfg    = SensorConfig(dropout_prob=1.0, seed=11)
        sensor = Sensor(cfg)
        for _ in range(50):
            assert sensor.read(21.0) is None

    def test_zero_noise_returns_exact_true_plus_bias(self):
        """With noise_std=0 and bias=0, reading should equal true_temp."""
        cfg    = SensorConfig(noise_std=0.0, dropout_prob=0.0, bias=0.0, seed=12)
        sensor = Sensor(cfg)
        assert abs(sensor.read(21.5) - 21.5) < 1e-9


