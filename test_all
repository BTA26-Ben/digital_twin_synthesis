class TestKalmanNominal:
    """Normal filter operation."""

    def test_update_moves_estimate_toward_observation(self):
        """After update with a high observation, estimate should increase."""
        kf = KalmanFilter(KalmanConfig(initial_temp=20.0))
        kf.predict()
        before = kf.x
        kf.update(reading=25.0)
        assert kf.x > before

    def test_uncertainty_decreases_after_update(self):
        """P should shrink after incorporating an observation."""
        kf = KalmanFilter(KalmanConfig(initial_temp=20.0))
        kf.predict()
        P_before = kf.P
        kf.update(reading=20.5)
        assert kf.P < P_before

    def test_uncertainty_increases_during_predict_only(self):
        """P should grow when predicting without any observation."""
        kf = KalmanFilter(KalmanConfig(initial_temp=20.0, initial_uncertainty=0.1))
        P_before = kf.P
        for _ in range(10):
            kf.predict()
        assert kf.P > P_before

    def test_filter_converges_toward_true_value(self):
        """After 50 steps of noisy readings around 21°C, estimate ≈ 21°C."""
        kf  = KalmanFilter(KalmanConfig(initial_temp=15.0, measurement_noise=0.25))
        rng = np.random.default_rng(99)
        for _ in range(50):
            noisy = 21.0 + float(rng.normal(0, 0.5))
            kf.step(reading=noisy)
        assert abs(kf.x - 21.0) < 1.0

    def test_sigma_property_is_sqrt_of_variance(self):
        """uncertainty property should equal sqrt(P)."""
        kf = KalmanFilter(KalmanConfig(initial_uncertainty=4.0))
        assert abs(kf.uncertainty - 2.0) < 1e-9


class TestKalmanEdgeCases:
    """Boundary and dropout conditions."""

    def test_none_reading_does_not_crash(self):
        """update(None) should return the prediction without raising."""
        kf = KalmanFilter(KalmanConfig())
        kf.predict()
        result = kf.update(reading=None)
        assert isinstance(result, float)

    def test_sustained_dropout_keeps_reasonable_estimate(self):
        """100 consecutive None readings should not cause explosion."""
        kf = KalmanFilter(KalmanConfig(initial_temp=21.0))
        for _ in range(100):
            kf.step(reading=None, outdoor_temp=10.0)
        assert 5.0 < kf.x < 40.0

    def test_step_convenience_matches_predict_then_update(self):
        """step() result should match calling predict() then update() manually."""
        cfg = KalmanConfig(initial_temp=20.0, seed=0) if hasattr(KalmanConfig, 'seed') else KalmanConfig(initial_temp=20.0)

        kf1 = KalmanFilter(KalmanConfig(initial_temp=20.0))
        kf2 = KalmanFilter(KalmanConfig(initial_temp=20.0))

        r = 21.3
        result_step = kf1.step(reading=r, outdoor_temp=10.0)
        kf2.predict(outdoor_temp=10.0)
        result_manual = kf2.update(reading=r)

        assert abs(result_step - result_manual) < 1e-9


class TestKalmanExceptional:
    """Extreme input values."""

    def test_very_cold_outdoor_stays_bounded(self):
        """Extreme outdoor temperature should not destabilise the filter."""
        kf = KalmanFilter(KalmanConfig(initial_temp=20.0))
        for _ in range(20):
            kf.step(reading=None, outdoor_temp=-40.0)
        assert kf.x > -50.0   # physically bounded

    def test_very_hot_outdoor_stays_bounded(self):
        """Very high outdoor temperature should not overflow."""
        kf = KalmanFilter(KalmanConfig(initial_temp=20.0))
        for _ in range(20):
            kf.step(reading=50.0, outdoor_temp=50.0)
        assert kf.x < 100.0


