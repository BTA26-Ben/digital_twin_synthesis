class TestSimulationIntegration:
    """Full pipeline from room physics → sensor → Kalman → DataFrame."""

    def test_run_produces_288_rows(self):
        """24 hours at 5-min intervals = exactly 288 timesteps."""
        df = run_simulation()
        assert len(df) == 288

    def test_all_required_columns_present(self):
        """DataFrame must contain every expected output column."""
        df       = run_simulation()
        required = [
            "timestamp_min", "hour", "true_temp", "noisy_reading",
            "kalman_estimate", "kalman_sigma", "outdoor_temp",
            "heater_on", "occupants", "error_raw", "error_kalman",
        ]
        for col in required:
            assert col in df.columns, f"Missing column: {col}"

    def test_kalman_rmse_lower_than_sensor_rmse(self):
        """Kalman filter must outperform the raw sensor on RMSE."""
        df           = run_simulation()
        raw_errors   = df["error_raw"].dropna()
        kalman_errors = df["error_kalman"]
        sensor_rmse  = float(raw_errors.pow(2).mean() ** 0.5)
        kalman_rmse  = float(kalman_errors.pow(2).mean() ** 0.5)
        assert kalman_rmse < sensor_rmse

    def test_temperatures_physically_bounded(self):
        """All temperatures should stay within physical bounds 0–40°C."""
        df = run_simulation()
        assert df["true_temp"].between(0, 40).all()
        assert df["kalman_estimate"].between(-5, 50).all()

    def test_determinism_same_seed_same_results(self):
        """Two runs with the same seed must produce identical DataFrames."""
        df1 = run_simulation()
        df2 = run_simulation()
        assert list(df1["true_temp"]) == list(df2["true_temp"])
        assert list(df1["kalman_estimate"]) == list(df2["kalman_estimate"])

    def test_different_seeds_give_different_sensor_readings(self):
        """Different sensor seeds must produce different noisy readings."""
        from sensor import SensorConfig
        df1 = run_simulation(sensor_cfg=SensorConfig(seed=42))
        df2 = run_simulation(sensor_cfg=SensorConfig(seed=99))
        assert list(df1["noisy_reading"]) != list(df2["noisy_reading"])


class TestSimulationPerformance:
    """Timing requirements."""

    def test_full_24h_simulation_under_5_seconds(self):
        """288-step simulation should complete well under 5 seconds."""
        t0 = time.perf_counter()
        run_simulation()
        elapsed = time.perf_counter() - t0
        assert elapsed < 5.0, f"Simulation took {elapsed:.2f}s — too slow"


class TestRoomSimulator:
    """Room physics model unit tests."""

    def test_heater_raises_temperature(self):
        """With heater on and cold outdoor temp, room should warm up."""
        cfg = RoomConfig(init_temp=15.0, outdoor_mean=5.0)
        sim = RoomSimulator(cfg)
        t0  = sim.temp
        for i in range(20):
            sim.step(minute_of_day=float(i * 5))
        assert sim.temp > t0

    def test_outdoor_temp_min_at_4am(self):
        """Outdoor temperature minimum should occur around 04:00 (240 min)."""
        sim   = RoomSimulator(RoomConfig())
        temps = [sim.outdoor_temp(float(m)) for m in range(0, 1440, 5)]
        min_idx = temps.index(min(temps))
        # Minimum should be around step 48 (240 min / 5 = 48)
        assert 40 <= min_idx <= 56

    def test_no_occupants_overnight(self):
        """Room should have zero occupants at midnight (minute 0)."""
        sim = RoomSimulator(RoomConfig())
        assert sim.occupants(0.0) == 0

    def test_occupants_during_business_hours(self):
        """Room should have occupants at 10:00 (minute 600)."""
        sim = RoomSimulator(RoomConfig(persons=5))
        assert sim.occupants(600.0) > 0
