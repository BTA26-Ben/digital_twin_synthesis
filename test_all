class TestEWASmootherNominal:
    """Normal smoother operation."""

    def test_high_alpha_moves_quickly_toward_reading(self):
        """Alpha=0.9 estimate should jump most of the way to a new reading."""
        sm = EWASmoother(SmootherConfig(alpha=0.9, initial_temp=20.0))
        est = sm.update(reading=30.0)
        # 0.9*30 + 0.1*20 = 27+2 = 29
        assert abs(est - 29.0) < 0.01

    def test_low_alpha_moves_slowly_toward_reading(self):
        """Alpha=0.1 estimate should barely shift toward a new reading."""
        sm = EWASmoother(SmootherConfig(alpha=0.1, initial_temp=20.0))
        est = sm.update(reading=30.0)
        # 0.1*30 + 0.9*20 = 3+18 = 21
        assert abs(est - 21.0) < 0.01

    def test_estimate_converges_after_many_readings(self):
        """After 100 steady readings at 25 C, estimate should be close to 25."""
        sm = EWASmoother(SmootherConfig(alpha=0.3, initial_temp=15.0))
        for _ in range(100):
            sm.update(25.0)
        assert abs(sm.estimate - 25.0) < 0.5

    def test_dropout_carries_estimate_forward(self):
        """update(None) should return the same estimate as before."""
        sm  = EWASmoother(SmootherConfig(alpha=0.5, initial_temp=21.0))
        before = sm.estimate
        result = sm.update(None)
        assert result == before
        assert sm.estimate == before

    def test_reset_restores_initial_temperature(self):
        """reset() should return estimate to initial_temp."""
        sm = EWASmoother(SmootherConfig(alpha=0.5, initial_temp=21.0))
        sm.update(30.0)
        sm.reset()
        assert abs(sm.estimate - 21.0) < 1e-9


class TestEWASmootherEdgeCases:
    """Boundary alpha values."""

    def test_alpha_one_equals_raw_reading(self):
        """With alpha=1.0, estimate should exactly equal the latest reading."""
        sm = EWASmoother(SmootherConfig(alpha=1.0, initial_temp=20.0))
        assert abs(sm.update(25.0) - 25.0) < 1e-9
        assert abs(sm.update(18.0) - 18.0) < 1e-9

    def test_sustained_dropout_holds_estimate_constant(self):
        """100 consecutive None readings should leave estimate unchanged."""
        sm    = EWASmoother(SmootherConfig(alpha=0.5, initial_temp=21.5))
        start = sm.estimate
        for _ in range(100):
            sm.update(None)
        assert abs(sm.estimate - start) < 1e-9

    def test_ewa_formula_is_correct(self):
        """Verify the EWA formula manually for two consecutive steps."""
        alpha = 0.4
        sm    = EWASmoother(SmootherConfig(alpha=alpha, initial_temp=20.0))
        e1    = sm.update(22.0)   # 0.4*22 + 0.6*20 = 8.8 + 12.0 = 20.8
        assert abs(e1 - 20.8) < 1e-6
        e2    = sm.update(22.0)   # 0.4*22 + 0.6*20.8 = 8.8 + 12.48 = 21.28
        assert abs(e2 - 21.28) < 1e-6


class TestMultiAlphaSmootherNominal:
    """Multi-alpha smoother operation."""

    def test_returns_estimate_for_every_alpha(self):
        """update() should return a dict with one entry per alpha."""
        mas  = MultiAlphaSmoother(alphas=[0.1, 0.5, 0.9])
        ests = mas.update(21.0)
        assert set(ests.keys()) == {0.1, 0.5, 0.9}

    def test_high_alpha_estimate_closer_to_reading(self):
        """alpha=0.9 estimate should be closer to reading than alpha=0.1."""
        mas  = MultiAlphaSmoother(alphas=[0.1, 0.9], initial_temp=15.0)
        ests = mas.update(25.0)
        assert abs(ests[0.9] - 25.0) < abs(ests[0.1] - 25.0)

    def test_best_alpha_returns_correct_alpha(self):
        """best_alpha() should return the alpha with minimum absolute error."""
        mas  = MultiAlphaSmoother(alphas=[0.1, 0.5, 0.9], initial_temp=20.0)
        ests = {0.1: 20.5, 0.5: 21.0, 0.9: 23.0}
        # true_temp = 21.0 → best should be 0.5 (error=0)
        assert mas.best_alpha(ests, true_temp=21.0) == 0.5

    def test_all_alphas_handle_dropout_gracefully(self):
        """update(None) should return floats for every alpha, not crash."""
        mas  = MultiAlphaSmoother(alphas=ALPHAS)
        ests = mas.update(None)
        assert len(ests) == len(ALPHAS)
        assert all(isinstance(v, float) for v in ests.values())


class TestEWASmootherExceptional:
    """Extreme temperature inputs."""

    def test_very_cold_reading_stays_bounded(self):
        """Extreme cold reading should not crash or overflow."""
        sm = EWASmoother(SmootherConfig(alpha=0.5, initial_temp=20.0))
        for _ in range(20):
            sm.update(-50.0)
        assert sm.estimate > -100.0

    def test_very_hot_reading_stays_bounded(self):
        """Extreme hot reading should not crash or overflow."""
        sm = EWASmoother(SmootherConfig(alpha=0.5, initial_temp=20.0))
        for _ in range(20):
            sm.update(100.0)
        assert sm.estimate < 200.0


