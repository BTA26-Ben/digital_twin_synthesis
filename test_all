class TestSimulationIntegration:

    def test_run_produces_288_rows(self):
        """24 hours at 5-min intervals = exactly 288 rows."""
        df = run_simulation()
        assert len(df) == 288

    def test_all_required_columns_present(self):
        """DataFrame must contain every expected output column."""
        df       = run_simulation()
        required = (
            ["timestamp_min", "hour", "true_temp", "noisy_reading", "best_alpha",
             "outdoor_temp", "heater_on", "occupants", "error_raw"]
            + [f"ewa_{a}"       for a in ALPHAS]
            + [f"error_ewa_{a}" for a in ALPHAS]
        )
        for col in required:
            assert col in df.columns, f"Missing column: {col}"

    def test_best_alpha_only_contains_valid_values(self):
        """best_alpha column should only contain values from ALPHAS list."""
        df = run_simulation()
        assert set(df["best_alpha"].unique()).issubset(set(ALPHAS))

    def test_at_least_one_ewa_beats_raw_sensor(self):
        """At least one EWA alpha should have lower RMSE than the raw sensor."""
        df          = run_simulation()
        sensor_rmse = float(df["error_raw"].dropna().pow(2).mean() ** 0.5)
        best_rmse   = min(
            float(df[f"error_ewa_{a}"].pow(2).mean() ** 0.5)
            for a in ALPHAS
        )
        assert best_rmse < sensor_rmse

    def test_temperatures_physically_bounded(self):
        """True temps should stay in 0–40 C; EWA estimates in -5 to 50 C."""
        df = run_simulation()
        assert df["true_temp"].between(0, 40).all()
        for alpha in ALPHAS:
            assert df[f"ewa_{alpha}"].between(-5, 50).all()

    def test_determinism_same_seed_same_results(self):
        """Two runs with the same seed must produce identical DataFrames."""
        df1 = run_simulation()
        df2 = run_simulation()
        assert list(df1["true_temp"])   == list(df2["true_temp"])
        assert list(df1["best_alpha"])  == list(df2["best_alpha"])
        assert list(df1["ewa_0.5"])     == list(df2["ewa_0.5"])

    def test_different_sensor_seeds_give_different_readings(self):
        """Different sensor seeds must produce different noisy readings."""
        df1 = run_simulation(sensor_cfg=SensorConfig(seed=42))
        df2 = run_simulation(sensor_cfg=SensorConfig(seed=99))
        assert list(df1["noisy_reading"]) != list(df2["noisy_reading"])

    def test_all_five_alphas_appear_as_best_at_some_point(self):
        """Every alpha should be best at least once over 24 hours."""
        df = run_simulation()
        assert set(df["best_alpha"].unique()) == set(ALPHAS)


class TestSimulationPerformance:

    def test_full_24h_simulation_under_5_seconds(self):
        """288-step simulation must complete well under 5 seconds."""
        t0 = time.perf_counter()
        run_simulation()
        elapsed = time.perf_counter() - t0
        assert elapsed < 5.0, f"Took {elapsed:.2f}s — exceeds 5s limit"


class TestRoomSimulator:

    def test_heater_raises_temperature(self):
        """With heater on and cold outdoor, room should warm up."""
        sim = RoomSimulator(RoomConfig(init_temp=15.0, outdoor_mean=5.0))
        t0  = sim.temp
        for i in range(20):
            sim.step(float(i * 5))
        assert sim.temp > t0

    def test_outdoor_min_at_4am(self):
        """Outdoor temperature minimum should occur around 04:00."""
        sim   = RoomSimulator(RoomConfig())
        temps = [sim.outdoor_temp(float(m)) for m in range(0, 1440, 5)]
        assert 40 <= temps.index(min(temps)) <= 56

    def test_no_occupants_at_midnight(self):
        sim = RoomSimulator(RoomConfig())
        assert sim.occupants(0.0) == 0

    def test_occupants_during_business_hours(self):
        sim = RoomSimulator(RoomConfig(persons=5))
        assert sim.occupants(600.0) > 0
