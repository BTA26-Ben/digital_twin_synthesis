class TestSensorNominal:

    def test_reading_close_to_true_value(self):
        """Mean of 500 readings should be within 0.3 C of true value."""
        s = Sensor(SensorConfig(noise_std=0.5, dropout_prob=0.0, seed=1))
        assert abs(float(np.mean([s.read(21.0) for _ in range(500)])) - 21.0) < 0.3

    def test_noise_std_matches_config(self):
        """Empirical std should be within 30% of configured noise_std."""
        s    = Sensor(SensorConfig(noise_std=1.0, dropout_prob=0.0, seed=2))
        vals = [s.read(20.0) for _ in range(1000)]
        assert 0.7 < float(np.std(vals)) < 1.3

    def test_bias_shifts_mean(self):
        """Mean reading should equal true_temp + bias."""
        s = Sensor(SensorConfig(noise_std=0.01, dropout_prob=0.0, bias=2.0, seed=3))
        assert abs(float(np.mean([s.read(20.0) for _ in range(300)])) - 22.0) < 0.1

    def test_stream_returns_correct_length(self):
        """stream() must return same length as input list."""
        s = Sensor(SensorConfig(dropout_prob=0.0, seed=4))
        assert len(s.stream([20., 21., 22., 23., 24.])) == 5

    def test_dropout_rate_approximately_correct(self):
        """Empirical dropout rate within 5 pp of configured rate."""
        s = Sensor(SensorConfig(noise_std=0.1, dropout_prob=0.2, seed=5))
        n = sum(1 for r in [s.read(20.) for _ in range(2000)] if r is None)
        assert abs(n / 2000 - 0.2) < 0.05


class TestSensorEdgeCases:

    def test_zero_dropout_never_drops(self):
        s = Sensor(SensorConfig(dropout_prob=0.0, seed=10))
        assert all(s.read(21.) is not None for _ in range(100))

    def test_full_dropout_always_none(self):
        s = Sensor(SensorConfig(dropout_prob=1.0, seed=11))
        assert all(s.read(21.) is None for _ in range(50))

    def test_zero_noise_returns_exact_value(self):
        s = Sensor(SensorConfig(noise_std=0.0, dropout_prob=0.0, seed=12))
        assert abs(s.read(21.5) - 21.5) < 1e-9


