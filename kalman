"""
kalman.py
---------
A one-dimensional discrete-time Kalman filter for estimating true room
temperature from noisy (and sometimes missing) sensor readings.

How it works in plain English
------------------------------
The filter maintains two numbers at every timestep:
  x  – its best estimate of the true temperature (°C)
  P  – its uncertainty about that estimate (variance, °C²)

Each timestep has two phases:

  PREDICT  – "What do I expect the temperature to be now, before I look
              at the sensor?" Uses the physics model: temperature drifts
              slowly toward outdoor temperature.

  UPDATE   – "I have a sensor reading — how should I adjust my estimate?"
              If the sensor is reliable (low R), trust it heavily.
              If it's noisy (high R), trust the physics model more.

When a sensor reading is missing (dropout), only the PREDICT step runs —
the filter keeps estimating using the physics model alone until readings
return.

Mathematics
-----------
Predict:
    x⁻  = F·x  +  B·u        (propagate state through physics model)
    P⁻  = F²·P  +  Q          (propagate uncertainty, add process noise)

Update (only when observation z is available):
    K   = P⁻ / (P⁻ + R)      (Kalman gain: how much to trust the sensor)
    x   = x⁻ + K·(z − x⁻)   (blend prediction with observation)
    P   = (1 − K)·P⁻          (reduce uncertainty after observing)

where:
    F   = state transition scalar   (how much temperature persists)
    B·u = control input             (outdoor temperature effect)
    Q   = process noise variance    (how much temp can change per step)
    R   = measurement noise variance (sensor noise, = noise_std²)

Public API
----------
KalmanConfig  – tuning parameters
KalmanFilter  – predict() and update() methods
"""

from __future__ import annotations

from dataclasses import dataclass
from typing import Optional


@dataclass
class KalmanConfig:
    """Tuning parameters for the 1-D Kalman filter.

    Attributes
    ----------
    process_noise : Q — how much the temperature can change per timestep
                    due to factors the model doesn't capture (draughts,
                    people entering, etc). Units: °C².
    measurement_noise : R — variance of the sensor noise.
                        Set to noise_std² from SensorConfig. Units: °C².
    initial_temp  : Starting temperature estimate (°C).
    initial_uncertainty : P₀ — how confident we are in initial_temp.
                          Large value = "I don't really know". Units: °C².
    f             : State transition scalar F.
                    1.0 = temperature is perfectly persistent (no model).
                    Values slightly below 1.0 model slow decay to ambient.
    """
    process_noise:       float = 0.01   # Q  — small: room temp changes slowly
    measurement_noise:   float = 0.25   # R  — matches noise_std=0.5 → 0.5²
    initial_temp:        float = 20.0   # x₀
    initial_uncertainty: float = 2.0    # P₀ — start uncertain
    f:                   float = 0.999  # F  — temperature is very persistent


class KalmanFilter:
    """1-D Kalman filter for room temperature estimation.

    Parameters
    ----------
    config : KalmanConfig with all tuning parameters.

    Usage
    -----
    >>> kf = KalmanFilter(KalmanConfig(measurement_noise=0.25))
    >>> kf.predict(outdoor_temp=8.0)
    >>> estimate = kf.update(sensor_reading=21.3)
    >>> uncertainty = kf.uncertainty   # 1-sigma, in °C
    """

    def __init__(self, config: KalmanConfig) -> None:
        self.config = config
        self.x: float = config.initial_temp        # current state estimate
        self.P: float = config.initial_uncertainty  # current uncertainty

    # ------------------------------------------------------------------
    # Core filter steps
    # ------------------------------------------------------------------

    def predict(self, outdoor_temp: float = 10.0, coupling: float = 0.001) -> float:
        """Predict step — advance the estimate one timestep using physics.

        The model: temperature drifts slightly toward outdoor temperature,
        scaled by a small coupling constant (heat loss through walls).

        Parameters
        ----------
        outdoor_temp : Current outdoor temperature in °C.
        coupling     : How strongly outdoor temp pulls the room temp per step.
                       Small value (0.001) = well-insulated room.

        Returns
        -------
        The predicted temperature estimate x⁻.
        """
        F = self.config.f
        Q = self.config.process_noise

        # Physics model: room drifts slightly toward outdoors
        control_input = coupling * (outdoor_temp - self.x)

        # Propagate state and uncertainty
        self.x = F * self.x + control_input
        self.P = F ** 2 * self.P + Q

        return self.x

    def update(self, reading: Optional[float]) -> float:
        """Update step — fuse a sensor reading with the current prediction.

        If reading is None (sensor dropped out), skip the update and
        return the prediction-only estimate. The filter handles dropout
        gracefully without any special-case code in the caller.

        Parameters
        ----------
        reading : Sensor reading in °C, or None if the packet was dropped.

        Returns
        -------
        The updated (posterior) temperature estimate.
        """
        if reading is None:
            # No observation — return prediction as-is
            # Uncertainty stays high, will decrease when readings return
            return self.x

        R = self.config.measurement_noise

        # Kalman gain: fraction of the innovation to incorporate
        # High gain (→1) = trust the sensor; Low gain (→0) = trust prediction
        K = self.P / (self.P + R)

        # Blend prediction with observation
        innovation = reading - self.x      # how wrong was the prediction?
        self.x = self.x + K * innovation
        self.P = (1.0 - K) * self.P        # uncertainty shrinks after update

        return self.x

    def step(self, reading: Optional[float], outdoor_temp: float = 10.0) -> float:
        """Convenience method: run predict then update in one call.

        Parameters
        ----------
        reading      : Sensor reading in °C, or None if dropped.
        outdoor_temp : Current outdoor temperature for the physics model.

        Returns
        -------
        The updated temperature estimate.
        """
        self.predict(outdoor_temp=outdoor_temp)
        return self.update(reading=reading)

    @property
    def uncertainty(self) -> float:
        """Return 1-sigma uncertainty (standard deviation) in °C.

        This is √P — the filter's confidence in its current estimate.
        Smaller = more confident. Typically drops from ~1.4°C initially
        down to ~0.1°C once the filter has warmed up.
        """
        return float(self.P ** 0.5)

